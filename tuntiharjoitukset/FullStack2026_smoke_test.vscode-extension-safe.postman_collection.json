{
  "info": {
    "name": "FullStack2026 Smoke Test (VS Code Extension Safe)",
    "description": "Tiny smoke test collection to verify import and basic JWT flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST Login (JWT)",
      "request": {
        "method": "POST",
        "description": "Login with studentNumber and copy token from response.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentNumber\": \"2912345\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "http://localhost:3001/api/students/login"
      }
    },
    {
      "name": "GET Profile (Auth Status)",
      "request": {
        "method": "GET",
        "description": "Check if token is valid. Add Authorization header manually: Bearer YOUR_TOKEN",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_TOKEN_HERE"
          }
        ],
        "url": "http://localhost:3001/api/students/profile"
      }
    },
    {
      "name": "GET Students",
      "request": {
        "method": "GET",
        "description": "Public endpoint smoke test.",
        "url": "http://localhost:3001/api/students"
      }
    }
  ]
}
