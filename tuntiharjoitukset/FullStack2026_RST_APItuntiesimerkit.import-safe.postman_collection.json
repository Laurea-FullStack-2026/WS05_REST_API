    {
      "name": "01_create_server",
      "description": "Introductory Express routes using in-memory arrays. Includes CRUD for students and courses with format/uniqueness checks.",
      "item": [
        {
          "name": "GET Students",
          "request": {
            "method": "GET",
            "description": "Returns all students from in-memory data. Useful for verifying that the students router is mounted and returning JSON.",
            "url": {
              "raw": "{{baseUrl}}/api/students"
            }
          }
        },
        {
          "name": "GET Student By StudentNumber",
          "request": {
            "method": "GET",
            "description": "Returns one student by student number from in-memory data. Responds with 404 if not found.",
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentNumber}}"
            }
          }
        },
        {
          "name": "POST Student",
          "request": {
            "method": "POST",
            "description": "Creates a new student in memory. Requires studentNumber, name, age and major. studentNumber must start with 29 and be unique.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentNumber\": \"{{studentNumberNew}}\",\n  \"name\": \"Test Student\",\n  \"age\": 23,\n  \"major\": \"Tietojenkäsittely\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/students"
            }
          }
        },
        {
          "name": "PUT Student",
          "request": {
            "method": "PUT",
            "description": "Fully replaces an existing student by student number in memory. Requires all fields and validates format/uniqueness.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentNumber\": \"{{studentNumber}}\",\n  \"name\": \"Updated Student\",\n  \"age\": 24,\n  \"major\": \"Tietotekniikka\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentNumber}}"
            }
          }
        },
        {
          "name": "DELETE Student",
          "request": {
            "method": "DELETE",
            "description": "Deletes a student by student number from in-memory storage.",
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentNumber}}"
            }
          }
        },
        {
          "name": "GET Courses",
          "request": {
            "method": "GET",
            "description": "Returns all courses from in-memory data.",
            "url": {
              "raw": "{{baseUrl}}/api/courses"
